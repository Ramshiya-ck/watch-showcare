---
---

<section class="py-16 md:py-24 bg-bg-light dark:bg-[#090909] border-b border-black/5 dark:border-white/5 relative overflow-hidden theme-transition" id="newsletter">
  
  <!-- Subtle background glow -->
  <div class="absolute inset-0 bg-radial from-gold-400/5 via-transparent to-transparent opacity-60 pointer-events-none" />

  <div class="max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-6 items-center relative z-10">
    
    <!-- Left watch casing image profile (Columns 1-3) -->
    <div class="lg:col-span-3 flex justify-center lg:justify-start" id="newsletter-image-box">
      <div class="relative w-[180px] md:w-[220px] aspect-square overflow-hidden rounded-sm group">
        <!-- Overlay fade to match background black/light-cream -->
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-bg-light/40 to-bg-light dark:via-[#090909]/40 dark:to-[#090909] z-10 theme-transition" />
        <img 
          src="/images/newsletter_bg.png" 
          alt="Luxury Watch Profile detail" 
          class="w-full h-full object-cover transform scale-100 group-hover:scale-105 transition-transform duration-700 ease-out"
        />
      </div>
    </div>

    <!-- Center text section (Columns 4-8) -->
    <div class="lg:col-span-5 flex flex-col items-center lg:items-start text-center lg:text-left" id="newsletter-text-box">
      <span class="text-gold-400 text-[10px] tracking-[0.3em] font-semibold uppercase mb-2">
        STAY IN TIME
      </span>
      <h2 class="font-serif text-2xl md:text-3xl font-bold tracking-tight text-black dark:text-white uppercase mb-3 theme-transition">
        Join Our Exclusive Circle
      </h2>
      <p class="text-black/50 dark:text-white/50 text-xs font-light leading-relaxed max-w-sm theme-transition">
        Be the first to know about new collections, exclusive offers and timeless stories.
      </p>
    </div>

    <!-- Right form section (Columns 9-12) -->
    <div class="lg:col-span-4 w-full flex justify-center lg:justify-end" id="newsletter-form-box">
      <form class="flex flex-col sm:flex-row items-stretch w-full max-w-md gap-3" onsubmit="event.preventDefault(); alert('Subscribed successfully!');">
        <input 
          type="email" 
          placeholder="Enter your email" 
          required 
          class="bg-transparent border border-black/10 dark:border-white/10 hover:border-black/20 dark:hover:border-white/20 focus:border-gold-400 text-black dark:text-white placeholder-black/40 dark:placeholder-white/30 text-xs px-4 py-3.5 focus:outline-none transition-colors rounded-sm flex-grow font-light theme-transition"
        />
        <button 
          type="submit" 
          class="bg-gold-400 hover:bg-gold-500 text-[#090909] text-xs font-semibold tracking-[0.25em] px-6 py-3.5 rounded-sm transition-all duration-300 transform active:scale-98 uppercase whitespace-nowrap"
        >
          SUBSCRIBE
        </button>
      </form>
    </div>

  </div>
</section>

<!-- GSAP ScrollTrigger for Newsletter Section -->
<script>
  import { gsap } from 'gsap';

  gsap.from('#newsletter-image-box', {
    scrollTrigger: {
      trigger: '#newsletter',
      start: 'top 85%',
      toggleActions: 'play none none none',
    },
    x: -30,
    opacity: 0,
    duration: 1,
    ease: 'power2.out',
  });

  gsap.from('#newsletter-text-box > *', {
    scrollTrigger: {
      trigger: '#newsletter',
      start: 'top 85%',
      toggleActions: 'play none none none',
    },
    y: 30,
    opacity: 0,
    duration: 0.8,
    stagger: 0.15,
    ease: 'power2.out',
  });

  gsap.from('#newsletter-form-box', {
    scrollTrigger: {
      trigger: '#newsletter',
      start: 'top 85%',
      toggleActions: 'play none none none',
    },
    x: 30,
    opacity: 0,
    duration: 1,
    ease: 'power2.out',
  });
</script>
