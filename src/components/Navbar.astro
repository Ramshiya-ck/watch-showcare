---
import { User, ShoppingBag, Sun, Moon } from '@lucide/astro';
---

<header class="fixed top-0 left-0 w-full z-50 bg-[#FAF8F5]/75 dark:bg-[#090909]/75 backdrop-blur-md border-b border-black/5 dark:border-white/5 transition-all duration-300 theme-transition">
  <div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
    
    <!-- Logo -->
    <a href="/" class="text-black dark:text-white font-serif text-lg font-semibold tracking-[0.25em] hover:text-gold-400 dark:hover:text-gold-400 transition-colors uppercase">
      CLOFA ZANCAN
    </a>

    <!-- Navigation Links -->
    <nav class="hidden md:flex items-center gap-10">
      {[
        { name: 'HOME', href: '#', active: true },
        { name: 'ABOUT US', href: '#about' },
        { name: 'COLLECTIONS', href: '#collections' },
        { name: 'SERVICES', href: '#services' },
        { name: 'CONTACT US', href: '#contact' }
      ].map((link) => (
        <a 
          href={link.href} 
          class={`relative py-2 text-[11px] font-medium tracking-[0.2em] transition-colors duration-300 text-black/70 dark:text-white/80 hover:text-black dark:hover:text-white ${
            link.active ? 'text-gold-400 dark:text-gold-400 font-semibold' : ''
          }`}
        >
          {link.name}
          <span class={`absolute bottom-0 left-0 w-full h-[1px] bg-gold-400 scale-x-0 origin-left transition-transform duration-300 ease-out hover:scale-x-100 ${
            link.active ? 'scale-x-100' : ''
          }`} />
        </a>
      ))}
    </nav>

    <!-- Right Side Icons -->
    <div class="flex items-center gap-6 text-black/70 dark:text-white/80">
      <!-- Theme Toggle Button -->
      <button id="theme-toggle" aria-label="Toggle Theme" class="hover:text-gold-400 transition-colors cursor-pointer text-black/75 dark:text-white/80 flex items-center justify-center">
        <Sun class="w-5 h-5 stroke-[1.5] hidden dark:block" />
        <Moon class="w-5 h-5 stroke-[1.5] block dark:hidden" />
      </button>

      <button aria-label="Profile" class="hover:text-gold-400 transition-colors cursor-pointer">
        <User class="w-5 h-5 stroke-[1.5]" />
      </button>
      <button aria-label="Shopping Bag" class="hover:text-gold-400 transition-colors cursor-pointer relative">
        <ShoppingBag class="w-5 h-5 stroke-[1.5]" />
        <span class="absolute -top-1 -right-1 w-2 h-2 bg-gold-400 rounded-full"></span>
      </button>
      
      <!-- Mobile Menu Button (hamburger) -->
      <button id="mobile-menu-btn" class="md:hidden hover:text-gold-400 transition-colors cursor-pointer text-black dark:text-white" aria-label="Toggle Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h16M4 16h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[#FAF8F5] dark:bg-[#090909] border-b border-black/5 dark:border-white/5 px-6 py-6 transition-all duration-300 theme-transition">
    <nav class="flex flex-col gap-5">
      {[
        { name: 'HOME', href: '#' },
        { name: 'ABOUT US', href: '#about' },
        { name: 'COLLECTIONS', href: '#collections' },
        { name: 'SERVICES', href: '#services' },
        { name: 'CONTACT US', href: '#contact' }
      ].map((link) => (
        <a 
          href={link.href} 
          class="text-xs font-medium tracking-[0.2em] text-black/70 dark:text-white/80 hover:text-gold-400 transition-colors"
        >
          {link.name}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  // Mobile Menu Toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }

  // Header background fade on scroll
  const header = document.querySelector('header');
  window.addEventListener('scroll', () => {
    if (header) {
      if (window.scrollY > 50) {
        header.classList.add('bg-[#FAF8F5]/95', 'dark:bg-[#090909]/95', 'shadow-lg');
        header.classList.remove('bg-[#FAF8F5]/75', 'dark:bg-[#090909]/75');
      } else {
        header.classList.add('bg-[#FAF8F5]/75', 'dark:bg-[#090909]/75');
        header.classList.remove('bg-[#FAF8F5]/95', 'dark:bg-[#090909]/95', 'shadow-lg');
      }
    }
  });

  // Theme Toggle Control
  const themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  }
</script>
