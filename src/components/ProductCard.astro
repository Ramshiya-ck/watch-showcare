---
interface Props {
  image: string;
  title: string;
  edition: string;
  price: string;
}

const { image, title, edition, price } = Astro.props;
---

<div class="product-card group relative bg-black/[0.01] dark:bg-white/[0.02] backdrop-blur-md border border-black/5 dark:border-white/5 rounded-sm p-6 md:p-8 flex flex-col justify-between items-center text-center overflow-hidden transition-all duration-500 hover:border-gold-400/30 hover:bg-black/[0.03] dark:hover:bg-white/[0.04] shadow-[0_10px_30px_rgba(0,0,0,0.15)] dark:shadow-[0_10px_30px_rgba(0,0,0,0.5)]">
  
  <!-- Subtle lighting glow behind card on hover -->
  <div class="absolute inset-0 bg-radial from-gold-400/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none" />
  
  <!-- Watch Image Wrapper -->
  <div class="relative w-full aspect-square flex items-center justify-center mb-8">
    <!-- Watch shadow element -->
    <div class="absolute bottom-2 w-1/2 h-6 bg-black/20 dark:bg-black/60 blur-md rounded-full scale-0 group-hover:scale-100 transition-transform duration-500" />
    
    <img 
      src={image} 
      alt={title} 
      class="w-[80%] h-[80%] object-contain transform translate-y-2 group-hover:translate-y-0 group-hover:scale-105 transition-all duration-500 ease-out"
    />
  </div>

  <!-- Card Meta Details -->
  <div class="relative z-10 w-full">
    <h3 class="font-serif text-sm tracking-[0.2em] font-semibold text-black dark:text-white uppercase mb-1 group-hover:text-gold-400 transition-colors duration-300">
      {title}
    </h3>
    <p class="text-[10px] tracking-[0.15em] font-medium text-black/40 dark:text-white/40 uppercase mb-4">
      {edition}
    </p>
    <div class="text-gold-400 font-semibold text-sm tracking-[0.1em]">
      {price}
    </div>
  </div>
  
  <!-- Thin border-accent animation helper -->
  <span class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-gold-400/50 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-750 ease-out" />
</div>
