---
import { PenTool, Cpu, Settings, ClipboardCheck, Truck } from '@lucide/astro';

const steps = [
  {
    num: '01',
    title: 'DESIGN',
    icon: PenTool,
    desc: 'Inspired by heritage, defined by vision.'
  },
  {
    num: '02',
    title: 'ENGINEERING',
    icon: Cpu,
    desc: 'Precision engineered with perfection.'
  },
  {
    num: '03',
    title: 'ASSEMBLY',
    icon: Settings,
    desc: 'Hand-assembled by master watchmakers.'
  },
  {
    num: '04',
    title: 'TESTING',
    icon: ClipboardCheck,
    desc: 'Tested beyond industry standards.'
  },
  {
    num: '05',
    title: 'DELIVERY',
    icon: Truck,
    desc: 'Delivered to your wrist with pride.'
  }
];
---

<section id="process" class="py-24 md:py-32 bg-bg-light dark:bg-[#090909] border-b border-black/5 dark:border-white/5 relative overflow-hidden theme-transition">
  <div class="max-w-7xl mx-auto px-6 text-center">
    
    <!-- Section Heading -->
    <span class="text-gold-400 text-xs font-semibold tracking-[0.3em] uppercase mb-4 block">
      OUR PROCESS
    </span>
    
    <!-- Responsive Timeline Container -->
    <div class="relative w-full max-w-5xl mx-auto mt-16 md:mt-24">
      
      <!-- Connecting Line -->
      <!-- Desktop: horizontal line -->
      <div class="hidden md:block absolute top-9 left-[10%] right-[10%] h-[1px] bg-gradient-to-r from-gold-400/20 via-black/10 dark:via-white/10 to-gold-400/20 -z-0 theme-transition" />
      
      <!-- Mobile: vertical line -->
      <div class="block md:hidden absolute left-[31px] top-6 bottom-6 w-[1px] bg-gradient-to-b from-gold-400/20 via-black/10 dark:via-white/10 to-gold-400/20 -z-0 theme-transition" />

      <!-- Timeline Nodes -->
      <div class="flex flex-col md:flex-row justify-between items-start gap-12 md:gap-4 relative z-10">
        {steps.map((step) => (
          <div class="process-node flex flex-row md:flex-col items-center md:items-center text-left md:text-center w-full md:w-1/5 gap-6 md:gap-0 group">
            
            <!-- Icon Circle -->
            <div class="w-[64px] h-[64px] rounded-full bg-bg-light dark:bg-[#090909] border border-black/10 dark:border-white/10 flex items-center justify-center text-gold-400 group-hover:border-gold-400 group-hover:text-[#090909] dark:group-hover:text-white transition-all duration-300 md:mb-6 shadow-[0_5px_15px_rgba(0,0,0,0.1)] dark:shadow-[0_5px_15px_rgba(0,0,0,0.4)] shrink-0 theme-transition">
              <step.icon class="w-5 h-5 stroke-[1.5]" />
            </div>

            <!-- Content -->
            <div class="flex flex-col items-start md:items-center">
              <!-- Step Number & Title -->
              <span class="text-gold-400 text-[10px] tracking-[0.2em] font-semibold mb-1 block">
                {step.num}
              </span>
              <h3 class="font-serif text-xs font-semibold tracking-[0.2em] text-black dark:text-white uppercase mb-2 group-hover:text-gold-400 transition-colors duration-300 theme-transition">
                {step.title}
              </h3>
              <!-- Description -->
              <p class="text-black dark:text-white text-[11px] font-light leading-relaxed max-w-[160px] theme-transition">
                {step.desc}
              </p>
            </div>
            
          </div>
        ))}
      </div>

    </div>

  </div>
</section>

<!-- GSAP ScrollTrigger for Process Section -->
<script>
  import { gsap } from 'gsap';

  // Stagger node animations
  gsap.from('#process .process-node', {
    scrollTrigger: {
      trigger: '#process',
      start: 'top 80%',
      toggleActions: 'play none none none',
    },
    y: 35,
    opacity: 0,
    duration: 0.8,
    stagger: 0.15,
    ease: 'power2.out',
  });
</script>
